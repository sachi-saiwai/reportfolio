<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Loading Mock</title>
    <style>
      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
      }

      body {
        margin: 0;
        color: #21161f;
        font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        overflow: hidden;
      }

      .loader-screen {
        min-height: 100vh;
        position: fixed;
        inset: 0;
        display: grid;
        place-items: center;
        padding: 24px;
        background:
          linear-gradient(145deg, #fffafd, #ffd6eb),
          radial-gradient(circle at 50% 30%, rgba(255, 77, 162, 0.18), transparent 28rem);
      }

      .loader-panel {
        width: min(78vw, 760px);
        min-height: min(44vw, 420px);
        display: grid;
        place-content: center;
        gap: clamp(24px, 4vw, 42px);
        padding: clamp(28px, 6vw, 72px);
        background: linear-gradient(135deg, #ffffff, #ffe4f1);
        border: 1px solid rgba(255, 77, 162, 0.18);
        box-shadow:
          0 28px 90px rgba(187, 29, 110, 0.14),
          inset 0 1px 0 rgba(255, 255, 255, 0.9);
      }

      .loader-word {
        margin: 0;
        color: #161014;
        font-family: "Courier New", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
        font-size: clamp(26px, 3vw, 42px);
        line-height: 1;
        text-align: center;
        letter-spacing: 0;
        transition:
          opacity 280ms ease,
          transform 280ms ease;
      }

      .loader-word.is-changing {
        opacity: 0;
        transform: translateY(10px);
      }

      .loader-stars {
        display: flex;
        justify-content: center;
        gap: clamp(22px, 6vw, 58px);
      }

      .loader-star {
        width: clamp(66px, 10vw, 108px);
        aspect-ratio: 1;
        display: block;
        background: rgba(255, 124, 188, 0.28);
        clip-path: polygon(
          50% 0%,
          61% 34%,
          98% 35%,
          68% 56%,
          79% 91%,
          50% 70%,
          21% 91%,
          32% 56%,
          2% 35%,
          39% 34%
        );
        transform: scale(0.94);
        transition:
          background 360ms ease,
          filter 360ms ease,
          transform 360ms ease;
      }

      .loader-star.is-active {
        background: #ff7fbd;
        filter: none;
        transform: scale(1.04);
      }

      @media (max-width: 720px) {
        .loader-panel {
          width: min(100%, 460px);
          min-height: 360px;
        }

        .loader-stars {
          gap: 16px;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        *,
        *::before,
        *::after {
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }
    </style>
  </head>
  <body>
    <main aria-live="polite">
      <section class="loader-screen" data-loader>
        <div class="loader-panel">
          <p class="loader-word" data-loader-word>impulse...</p>
          <div class="loader-stars" aria-hidden="true">
            <span class="loader-star is-active"></span>
            <span class="loader-star"></span>
            <span class="loader-star"></span>
          </div>
        </div>
      </section>
    </main>

    <script>
      const loaderWord = document.querySelector("[data-loader-word]");
      const loaderStars = [...document.querySelectorAll(".loader-star")];

      const steps = [
        { label: "impulse...", activeStars: 1 },
        { label: "curiosity...", activeStars: 2 },
        { label: "creation!", activeStars: 3 },
      ];

      const setStep = (step) => {
        loaderWord.classList.add("is-changing");

        window.setTimeout(() => {
          loaderWord.textContent = step.label;
          loaderStars.forEach((star, index) => {
            star.classList.toggle("is-active", index < step.activeStars);
          });
          loaderWord.classList.remove("is-changing");
        }, 220);
      };

      const runLoading = () => {
        steps.forEach((step, index) => {
          window.setTimeout(() => setStep(step), index * 880);
        });
      };

      window.addEventListener("DOMContentLoaded", runLoading);
    </script>
  </body>
</html>
